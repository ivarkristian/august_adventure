# Preferred GitHub App authentication (recommended).
# Fill all three values to enable App mode.
AUGUST_GH_APP_ID=
AUGUST_GH_INSTALLATION_ID=
AUGUST_GH_APP_PRIVATE_KEY_PATH=/home/ikw/.config/august-github-app.pem

# Optional fallback: classic token mode.
# Leave placeholder to disable PAT mode.
AUGUST_GITHUB_TOKEN=ghp_replace_me

# Public repository to monitor.
AUGUST_GITHUB_REPO=ivarkristian/august_adventure
AUGUST_REPO_URL=https://github.com/ivarkristian/august_adventure.git

# Local checkout path on the August host.
AUGUST_REPO_DIR=/home/ikw/august_adventure

# Set to 1 to run even without new commits.
AUGUST_FORCE=0

# Issue caps per run.
AUGUST_MAX_BUGS=3
AUGUST_MAX_FEATURES=3

# Optional Discord channel to pin latest brief.
# If empty, latest brief is pinned in owner DM.
AUGUST_DISCORD_PIN_CHANNEL_ID=

# Preferred destination for all playtest summaries.
# Set either channel ID or channel name (without #).
AUGUST_DISCORD_REPORT_CHANNEL_ID=
AUGUST_DISCORD_REPORT_CHANNEL_NAME=august-adventure
