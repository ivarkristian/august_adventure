# Preferred GitHub App authentication (recommended).
# Fill all three values to enable App mode.
AUGUST_GH_APP_ID=
AUGUST_GH_INSTALLATION_ID=
AUGUST_GH_APP_PRIVATE_KEY_PATH=/home/ikw/.config/august-github-app.pem

# Optional fallback: classic token mode.
# Leave placeholder to disable PAT mode.
AUGUST_GITHUB_TOKEN=ghp_replace_me

# Public repository to monitor.
AUGUST_GITHUB_REPO=owner/repository
AUGUST_REPO_URL=https://github.com/owner/repository.git

# Local checkout path on the host. Runner requires a game profile at:
#   ${AUGUST_REPO_DIR}/ops/august/game_profile.json
AUGUST_REPO_DIR=$HOME/.picoclaw/workspace/august_adventure

# Role workspace root used for PicoClaw role-specific AGENT.md files.
AUGUST_PICOCLAW_ROLE_WORKSPACES_ROOT=$HOME/.picoclaw/workspace/august-playtest/workspaces

# Set to 1 to run even without new commits.
AUGUST_FORCE=0

# Repo sync mode:
# - hard-reset (default): fetch + reset to origin/main
# - fast-forward: fetch + pull --ff-only
# - none: do not pull/reset, test current checkout as-is
AUGUST_SYNC_MODE=hard-reset

# Issue caps.
AUGUST_MAX_BUGS=3

# Feature issue cap per role (QA/Narrative/Puzzle/Agency/Publisher).
# Backward-compatible fallback: AUGUST_MAX_FEATURES
AUGUST_MAX_FEATURES_PER_ROLE=3
AUGUST_MAX_FEATURES=3

# Minimum number of substantive role outputs required before creating game issues.
AUGUST_MIN_SUBSTANTIVE_ROLES=2

# Optional model override for consultant calls.
# If empty, PicoClaw default model is used.
AUGUST_PICOCLAW_MODEL=

# Optional escalation model used only when earlier consultant attempts fail.
# Escalation starts at retry tier index (0-based). Default 2 means third attempt.
AUGUST_PICOCLAW_ESCALATION_MODEL=
AUGUST_PICOCLAW_ESCALATE_AFTER_TIER=2

# Session namespace for role-split consultant calls.
AUGUST_PICOCLAW_SESSION_PREFIX=cli:august-playtest

# Max commands (actions) for each unscripted role playthrough.
AUGUST_ROLE_MAX_ACTIONS=32

# Backward-compatible alias for action cap.
AUGUST_ROLE_MAX_TURNS=32

# Max location changes allowed per role run. Set to 0 for no cap.
AUGUST_ROLE_MAX_LOCATION_CHANGES=16

# Transcript lines included per turn decision prompt.
AUGUST_ROLE_TRANSCRIPT_WINDOW=14

# Approximate character budget per role prompt before compression retries.
AUGUST_CONTEXT_CHAR_BUDGET=14000

# Reset PicoClaw main session context before consultant calls (recommended).
AUGUST_RESET_PICOCLAW_MAIN_SESSION=1

# Number of local debug bundles to retain.
AUGUST_DEBUG_KEEP_RUNS=50

# Optional Discord channel to pin latest brief.
# If empty, latest brief is pinned in owner DM.
AUGUST_DISCORD_PIN_CHANNEL_ID=

# Preferred destination for all playtest summaries.
# Set either channel ID or channel name (without #).
AUGUST_DISCORD_REPORT_CHANNEL_ID=
AUGUST_DISCORD_REPORT_CHANNEL_NAME=august-adventure
